{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "jsx": "preserve",
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./*"
      ],
      "@/components/*": [
        "./components/*"
      ],
      "@/lib/*": [
        "./lib/*"
      ],
      "@/styles/*": [
        "./styles/*"
      ],
      "@jinge/generators": [
        "../../packages/generators"
      ],
      "@jinge/generators/*": [
        "../../packages/generators/*"
      ],
      "@jinge/schemas": [
        "../../packages/schemas"
      ],
      "@jinge/schemas/*": [
        "../../packages/schemas/*"
      ],
      "@jinge/utils": [
        "../../packages/utils"
      ],
      "@jinge/utils/*": [
        "../../packages/utils/*"
      ],
      "@jinge/integrations": [
        "../../packages/integrations"
      ],
      "@jinge/integrations/*": [
        "../../packages/integrations/*"
      ]
    },
    "allowJs": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "noEmit": true,
    "incremental": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "app",
    "components",
    "lib",
    "styles",
    "next-env.d.ts",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
